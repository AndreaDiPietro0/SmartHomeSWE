@startuml
!pragma layout smetana

left to right direction
skinparam packageStyle rectangle

' Attori
actor "Utente\n" as User
actor "Ambiente" as Environment

package "Sistema Smart Home" {

    ' sfera composite
    usecase "Gestire casa e stanze" as UC_ManageHouse
    usecase "Interagire con dispositivi smart" as UC_ManageDevices
    usecase "Monitorare consumo energetico" as UC_CheckConsumption

    ' sfera adapter
    usecase "Controllare vecchi dispositivi" as UC_ManageOld

    ' sfera observer
    usecase "Rilevamento intrusione" as UC_Detect
    usecase "Notificare dispositivi iscritti" as UC_Notify
    usecase "Attivare sirena" as UC_SoundAlarm
    usecase "Ricevere notifica su app" as UC_AppAlert
    usecase "Consultare video telecamera" as UC_LiveFeed
}

' connessioni attori
User --> UC_ManageHouse
User --> UC_ManageDevices
User --> UC_CheckConsumption
User --> UC_LiveFeed

Environment --> UC_Detect

'relazione tra i casi d'uso

' il controllo della casa include anche il controllo dei singoli dispositivi
UC_ManageHouse ..> UC_ManageDevices : <<include>>

' il controllo dei dispositivi legacy è un'estensione del controllo standard
UC_ManageDevices <.. UC_ManageOld : <<extend>>

' Effetto catena dell'emergenza (Observer)
UC_Detect ..> UC_Notify : <<include>>
UC_Notify ..> UC_SoundAlarm : <<include>>
UC_Notify ..> UC_AppAlert : <<include>>

' la notifica push porta l'utente ad aprire la telecamera
UC_AppAlert ..> UC_LiveFeed : <<include>>

@enduml