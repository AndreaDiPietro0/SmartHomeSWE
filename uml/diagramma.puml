@startuml
!pragma layout smetana
skinparam classAttributeIconSize 0

' Composite e adapter
package "Composite & Adapter Patterns" <<Rectangle>> {

    interface SmartDevice {
        + activate() : void
        + deactivate() : void
        + getConsumption() : double
    }

   class LightBulb {
       - baseConsumption : double
       - isOn : boolean
       + LightBulb(baseConsumption: double)
       + activate() : void
       + deactivate() : void
       + getConsumption() : double
   }

    class Thermostat {
        - baseConsumption : double
        - isOn : boolean
        + Thermostat(baseConsumption: double)
        + activate() : void
        + deactivate() : void
        + getConsumption() : double
    }

    class SmartCamera {
            - location : String
            - baseConsumption : double
            - isRecording : boolean
            + SmartCamera(location: String)
            + activate() : void
            + deactivate() : void
            + getConsumption() : double
            + getLiveFeed() : String
        }

    class Room {
        - name : String
        - devices : List<SmartDevice>
        + Room(name: String)
        + addDevice(device: SmartDevice) : void
        + activate() : void
        + deactivate() : void
        + getConsumption() : double
    }

    class House {
        - name : String
        - areas : List<SmartDevice>
        + House(name: String)
        + addArea(area: SmartDevice) : void
        + activate() : void
        + deactivate() : void
        + getConsumption() : double
    }

    class OldSpeaker {
        + playMusic() : void
        + stopMusic() : void
    }

    class OldSpeakerAdapter {
            - oldSpeaker : OldSpeaker
            - isPlaying : boolean
            - powerDraw : double
            + OldSpeakerAdapter(legacySpeaker: OldSpeaker)
            + activate() : void
            + deactivate() : void
            + getConsumption() : double
        }

    class OldTV {
        + powerOn() : void
        + powerOff() : void
    }

    class OldTVAdapter {
        - oldTV : OldTV
        - isOn : boolean
        - powerDraw : double
        + OldTVAdapter(vecchiaTV: OldTV)
        + activate() : void
        + deactivate() : void
        + getConsumption() : double
    }

    ' relazioni composite
    SmartDevice <|.. LightBulb
    SmartDevice <|.. Thermostat
    SmartDevice <|.. SmartCamera
    SmartDevice <|.. Room
    SmartDevice <|.. House

    Room o--> SmartDevice : contains
    House o--> SmartDevice : contains

    ' relazioni adapter
    SmartDevice <|.. OldSpeakerAdapter
    SmartDevice <|.. OldTVAdapter
    OldSpeakerAdapter --> OldSpeaker : adapts
    OldTVAdapter --> OldTV : adapts
}

' observer e sensore che fa da ponte
package "Observer Pattern" <<Rectangle>> {

    interface SensorObserver {
        + update(event: String) : void
    }

    class MobileApp {
        - securityCam : SmartCamera
        + MobileApp(securityCam: SmartCamera)
        + turnOn(device: SmartDevice, name: String) : void
        + turnOff(device: SmartDevice, name: String) : void
        + checkConsumption(device: SmartDevice, name: String) : void
        + update(event: String) : void
    }

    class AlarmSystem {
        - isRinging : boolean
        + update(event: String) : void
        + isRinging() : boolean
    }

    class MotionSensor {
        - location : String
        - observers : List<SensorObserver>
        - isActive : boolean
        - powerDraw : double
        + MotionSensor(location: String)
        + activate() : void
        + deactivate() : void
        + getConsumption() : double
        + attach(o: SensorObserver) : void
        + detach(o: SensorObserver) : void
        - notifyObservers(event: String) : void
        + detectIntruder() : void
    }

    ' MotionSensor fa da ponte tra i pattern, è sia SmartDevice nel composite che subject nell'observer
    SmartDevice <|.. MotionSensor

    ' relazioni observer
    SensorObserver <|.. MobileApp
    SensorObserver <|.. AlarmSystem
    MotionSensor o--> SensorObserver : notifies

    ' connessioni della MobileApp
    MobileApp --> SmartCamera : gets feed from
    MobileApp ..> SmartDevice : controls
}

' note
note bottom of House : "radice del composite"
note bottom of LightBulb : "foglia"
note bottom of OldSpeakerAdapter : "adapter"
note bottom of OldTVAdapter : "adapter"
note top of MotionSensor : "subject & foglia"
note right of MobileApp : "Observer & Client\n(interagisce con i dispositivi)"

@enduml