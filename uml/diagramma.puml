@startuml
!pragma layout smetana
skinparam classAttributeIconSize 0

' Composite e adapter
package "Composite & Adapter Patterns" <<Rectangle>> {

    interface SmartDevice {
        + activate() : void
        + deactivate() : void
        + getConsumption() : double
    }

    class LightBulb {
        - baseConsumption : double
        + activate() : void
        + deactivate() : void
        + getConsumption() : double
    }

    class Thermostat {
        - baseConsumption : double
        + activate() : void
        + deactivate() : void
        + getConsumption() : double
    }

    class SmartCamera {
        - baseConsumption : double
        + activate() : void
        + deactivate() : void
        + getConsumption() : double
        + getLiveFeed() : String
    }

    class Room {
        - devices : List<SmartDevice>
        + addDevice(d: SmartDevice) : void
        + activate() : void
        + deactivate() : void
        + getConsumption() : double
    }

    class House {
        - areas : List<SmartDevice>
        + addArea(d: SmartDevice) : void
        + activate() : void
        + deactivate() : void
        + getConsumption() : double
    }

    class OldSpeaker {
        + playMusic() : void
        + stopMusic() : void
    }

    class OldSpeakerAdapter {
        - oldSpeaker : OldSpeaker
        + activate() : void
        + deactivate() : void
        + getConsumption() : double
    }

    class OldTV {
        + powerOn() : void
        + powerOff() : void
    }

    class OldTVAdapter {
        - oldTV : OldTV
        + activate() : void
        + deactivate() : void
        + getConsumption() : double
    }

    ' relazioni composite
    SmartDevice <|.. LightBulb
    SmartDevice <|.. Thermostat
    SmartDevice <|.. SmartCamera
    SmartDevice <|.. Room
    SmartDevice <|.. House

    Room o--> SmartDevice : contains
    House o--> SmartDevice : contains

    ' relazioni adapter
    SmartDevice <|.. OldSpeakerAdapter
    SmartDevice <|.. OldTVAdapter
    OldSpeakerAdapter --> OldSpeaker : adapts
    OldTVAdapter --> OldTV : adapts
}

' Observer e sensore che fa da ponte
package "Observer Pattern" <<Rectangle>> {

    interface SensorObserver {
        + update(event: String) : void
    }

    class MobileApp {
        - securityCam : SmartCamera
        + turnOn(device: SmartDevice, deviceName: String) : void
        + turnOff(device: SmartDevice, deviceName: String) : void
        + checkConsumption(device: SmartDevice, deviceName: String) : void
        + update(event: String) : void
    }

    class AlarmSystem {
        + update(event: String) : void
    }

    class MotionSensor {
        - observers : List<SensorObserver>
        - isActive : boolean
        - powerDraw : double
        + activate() : void
        + deactivate() : void
        + getConsumption() : double
        + attach(o: SensorObserver) : void
        + detach(o: SensorObserver) : void
        + notifyObservers(event: String) : void
        + detectIntruder() : void
    }

    ' MotionSensor fa da ponte tra i pattern, è sia SmartDevice nel composite che subject nell'observer
    SmartDevice <|.. MotionSensor

    ' relazioni observer
    SensorObserver <|.. MobileApp
    SensorObserver <|.. AlarmSystem
    MotionSensor o--> SensorObserver : notifies

    ' connessioni della MobileApp
    MobileApp --> SmartCamera : gets feed from
    MobileApp ..> SmartDevice : controls
}

' note
note bottom of House : "Root Composite"
note bottom of LightBulb : "Leaf"
note bottom of OldSpeakerAdapter : "Adapter 1"
note bottom of OldTVAdapter : "Adapter 2"
note top of MotionSensor : "Subject & Leaf"
note right of MobileApp : "Observer & Client\n(Gestisce i dispositivi e reagisce alle emergenze)"

@enduml